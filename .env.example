# ===========================================================================
# 이 파일은 "예시 템플릿"이다. 실제 시크릿은 여기 적지 말고 .env 에 넣어라.
# .env 는 .gitignore 에 포함되어 커밋되지 않는다. (Claude는 .env 에 접근하지 않음)
# 사용법:  cp .env.example .env   후 .env 의 빈 값을 채운다.
# ===========================================================================

# --- AI (LLM) 제공자: OpenAI ---
# 판단 에이전트 / 목표플랜 근거 / 뉴스 센티먼트 / 시황 방향성 / 리포트 코멘트에 사용.
# platform.openai.com/api-keys 에서 발급 (sk-...).
OPENAI_API_KEY=
# 사용할 모델. 원하는 모델로 변경 가능 (예: gpt-4o, gpt-4o-mini, o4-mini 등).
OPENAI_MODEL=gpt-4o
# (선택) Azure/프록시 등 커스텀 엔드포인트를 쓰면 지정. 비우면 OpenAI 기본 사용.
OPENAI_BASE_URL=

# --- Robinhood (거래/조회) ---
# Robinhood는 공개 API 키가 없다 — robinhood-trading MCP 서버로 인증/조회/주문한다.
# 실거래 MCP provider를 켜려면 true. 기본 false → MockProvider(실거래/실조회 없음, 안전 기본값).
ROBINHOOD_MCP_ENABLED=false

# --- 저장소 / 캐시 ---
DATABASE_URL=sqlite:///./trading_bot.db
REDIS_URL=redis://localhost:6379/0
